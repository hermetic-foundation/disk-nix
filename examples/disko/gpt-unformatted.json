{
  "apply": {
    "allowDestructive": true,
    "allowFormat": true,
    "allowGrow": true,
    "allowOffline": true,
    "allowPotentialDataLoss": true,
    "allowShrink": true,
    "requireBackup": false
  },
  "disks": {
    "/dev/sdb": {
      "metadata": {
        "diskoDiskNames": [
          "main"
        ],
        "diskoSource": "main",
        "originalDevices": [
          "/dev/vdb"
        ]
      },
      "operation": "create",
      "partitionType": "gpt"
    }
  },
  "filesystems": {
    "main:ESP": {
      "device": "/dev/sdb1",
      "fsType": "vfat",
      "metadata": {
        "diskoSource": "main",
        "diskoType": "filesystem"
      },
      "mountpoint": "/boot",
      "operation": "format",
      "options": [
        "umask=0077"
      ],
      "preserveData": false
    },
    "main:root": {
      "device": "/dev/sdb3",
      "fsType": "ext4",
      "metadata": {
        "diskoSource": "main",
        "diskoType": "filesystem"
      },
      "mountpoint": "/",
      "operation": "format",
      "preserveData": false
    }
  },
  "metadata": {
    "source": "gpt-unformatted.nix",
    "upstream": "nix-community/disko"
  },
  "partitions": {
    "main:empty": {
      "device": "/dev/sdb",
      "end": "1125MiB",
      "metadata": {
        "diskoSource": "main"
      },
      "name": "empty",
      "operation": "create",
      "partitionNumber": "2",
      "partitionType": "primary",
      "size": "1G",
      "start": "101MiB",
      "target": "/dev/sdb2"
    },
    "main:ESP": {
      "device": "/dev/sdb",
      "end": "101MiB",
      "metadata": {
        "diskoPartitionType": "EF00",
        "diskoSource": "main"
      },
      "name": "ESP",
      "operation": "create",
      "partitionNumber": "1",
      "partitionType": "primary",
      "size": "100M",
      "start": "1MiB",
      "target": "/dev/sdb1"
    },
    "main:root": {
      "device": "/dev/sdb",
      "end": "100%",
      "metadata": {
        "diskoSource": "main"
      },
      "name": "root",
      "operation": "create",
      "partitionNumber": "3",
      "partitionType": "primary",
      "size": "100%",
      "start": "1125MiB",
      "target": "/dev/sdb3"
    }
  },
  "version": 1
}
