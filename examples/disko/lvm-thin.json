{
  "apply": {
    "allowDestructive": true,
    "allowFormat": true,
    "allowGrow": true,
    "allowOffline": true,
    "allowPotentialDataLoss": true,
    "allowShrink": true,
    "requireBackup": false
  },
  "disks": {
    "/dev/sdb": {
      "metadata": {
        "diskoDiskNames": [
          "main"
        ],
        "diskoSource": "main",
        "originalDevices": [
          "/dev/vdb"
        ]
      },
      "operation": "create",
      "partitionType": "gpt"
    }
  },
  "filesystems": {
    "main:ESP": {
      "device": "/dev/sdb1",
      "fsType": "vfat",
      "metadata": {
        "diskoSource": "main",
        "diskoType": "filesystem"
      },
      "mountpoint": "/boot",
      "operation": "format",
      "options": [
        "umask=0077"
      ],
      "preserveData": false
    },
    "mainpool/home": {
      "device": "/dev/mainpool/home",
      "fsType": "ext4",
      "metadata": {
        "diskoSource": "lvm:mainpool/home",
        "diskoType": "filesystem"
      },
      "mountpoint": "/home",
      "operation": "format",
      "preserveData": false
    },
    "mainpool/root": {
      "device": "/dev/mainpool/root",
      "fsType": "ext4",
      "metadata": {
        "diskoSource": "lvm:mainpool/root",
        "diskoType": "filesystem"
      },
      "mountpoint": "/",
      "operation": "format",
      "options": [
        "defaults"
      ],
      "preserveData": false
    }
  },
  "metadata": {
    "source": "lvm-thin.nix",
    "upstream": "nix-community/disko"
  },
  "partitions": {
    "main:ESP": {
      "device": "/dev/sdb",
      "end": "501MiB",
      "metadata": {
        "diskoPartitionType": "EF00",
        "diskoSource": "main"
      },
      "name": "ESP",
      "operation": "create",
      "partitionNumber": "1",
      "partitionType": "primary",
      "size": "500M",
      "start": "1MiB",
      "target": "/dev/sdb1"
    },
    "main:primary": {
      "device": "/dev/sdb",
      "end": "100%",
      "metadata": {
        "diskoSource": "main"
      },
      "name": "primary",
      "operation": "create",
      "partitionNumber": "2",
      "partitionType": "primary",
      "size": "100%",
      "start": "501MiB",
      "target": "/dev/sdb2"
    }
  },
  "physicalVolumes": {
    "/dev/sdb2": {
      "device": "/dev/sdb2",
      "metadata": {
        "diskoSource": "main"
      },
      "operation": "create"
    }
  },
  "version": 1,
  "volumeGroups": {
    "mainpool": {
      "device": "/dev/sdb2",
      "devices": [
        "/dev/sdb2"
      ],
      "metadata": {
        "diskoSource": "main"
      },
      "operation": "create"
    }
  },
  "volumes": {
    "mainpool/home": {
      "desiredSize": "10M",
      "metadata": {
        "diskoSource": "lvm_vg:mainpool",
        "lvmType": "thinlv"
      },
      "operation": "create",
      "target": "mainpool/home"
    },
    "mainpool/raw": {
      "desiredSize": "10M",
      "metadata": {
        "diskoSource": "lvm_vg:mainpool"
      },
      "operation": "create",
      "target": "mainpool/raw"
    },
    "mainpool/root": {
      "desiredSize": "10M",
      "metadata": {
        "diskoSource": "lvm_vg:mainpool",
        "lvmType": "thinlv"
      },
      "operation": "create",
      "target": "mainpool/root"
    },
    "mainpool/thinpool": {
      "desiredSize": "100M",
      "metadata": {
        "diskoSource": "lvm_vg:mainpool",
        "lvmType": "thin-pool"
      },
      "operation": "create",
      "target": "mainpool/thinpool"
    }
  }
}
