{
  "apply": {
    "allowDestructive": true,
    "allowFormat": true,
    "allowGrow": true,
    "allowOffline": true,
    "allowPotentialDataLoss": true,
    "allowShrink": true,
    "requireBackup": false
  },
  "btrfsSubvolumes": {
    "disk2:p2:/root": {
      "metadata": {
        "diskoSource": "disk2:p2",
        "parentFilesystem": "disk2:p2"
      },
      "mountpoint": "/",
      "operation": "create",
      "options": [
        "rw",
        "relatime",
        "ssd"
      ],
      "target": "/root"
    }
  },
  "disks": {
    "/dev/sdb": {
      "metadata": {
        "diskoDiskName": "disk1",
        "diskoSource": "disk1",
        "originalDevice": "/dev/sda"
      },
      "operation": "create",
      "partitionType": "gpt"
    },
    "/dev/sdc": {
      "metadata": {
        "diskoDiskName": "disk2",
        "diskoSource": "disk2",
        "originalDevice": "/dev/sdb"
      },
      "operation": "create",
      "partitionType": "gpt"
    }
  },
  "filesystems": {
    "disk1:ESP": {
      "device": "/dev/sdb1",
      "fsType": "vfat",
      "metadata": {
        "diskoSource": "disk1",
        "diskoType": "filesystem"
      },
      "mountpoint": "/boot",
      "operation": "format",
      "options": [
        "umask=0077"
      ],
      "preserveData": false
    },
    "disk2:p2": {
      "device": "/dev/mapper/p2",
      "fsType": "btrfs",
      "metadata": {
        "diskoSource": "disk2:p2",
        "diskoType": "filesystem",
        "extraArgs": [
          "-d raid1",
          "/dev/mapper/p1"
        ]
      },
      "mountpoint": "disk2:p2",
      "operation": "format",
      "preserveData": false
    }
  },
  "luks": {
    "devices": {
      "p1": {
        "device": "/dev/sdb2",
        "metadata": {
          "diskoSource": "disk1",
          "settings": {
            "allowDiscards": true,
            "keyFile": "/tmp/secret.key"
          }
        },
        "operation": "format",
        "preserveData": false
      },
      "p2": {
        "device": "/dev/sdc1",
        "metadata": {
          "diskoSource": "disk2",
          "settings": {
            "allowDiscards": true,
            "keyFile": "/tmp/secret.key"
          }
        },
        "operation": "format",
        "preserveData": false
      }
    }
  },
  "metadata": {
    "source": "luks-btrfs-raid.nix",
    "upstream": "nix-community/disko"
  },
  "partitions": {
    "disk1:crypt_p1": {
      "device": "/dev/sdb",
      "end": "100%",
      "metadata": {
        "diskoSource": "disk1"
      },
      "name": "crypt_p1",
      "operation": "create",
      "partitionNumber": "2",
      "partitionType": "primary",
      "size": "100%",
      "start": "513MiB",
      "target": "/dev/sdb2"
    },
    "disk1:ESP": {
      "device": "/dev/sdb",
      "end": "513MiB",
      "metadata": {
        "diskoPartitionType": "EF00",
        "diskoSource": "disk1"
      },
      "name": "ESP",
      "operation": "create",
      "partitionNumber": "1",
      "partitionType": "primary",
      "size": "512M",
      "start": "1MiB",
      "target": "/dev/sdb1"
    },
    "disk2:crypt_p2": {
      "device": "/dev/sdc",
      "end": "100%",
      "metadata": {
        "diskoSource": "disk2"
      },
      "name": "crypt_p2",
      "operation": "create",
      "partitionNumber": "1",
      "partitionType": "primary",
      "size": "100%",
      "start": "1MiB",
      "target": "/dev/sdc1"
    }
  },
  "version": 1
}
