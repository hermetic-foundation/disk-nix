{
  "apply": {
    "allowDestructive": true,
    "allowFormat": true,
    "allowGrow": true,
    "allowOffline": true,
    "allowPotentialDataLoss": true,
    "allowShrink": true,
    "requireBackup": false
  },
  "disks": {
    "/dev/sdb": {
      "metadata": {
        "diskoDiskNames": [
          "main"
        ],
        "diskoSource": "main",
        "originalDevices": [
          "/dev/disk/by-id/some-disk-id"
        ]
      },
      "operation": "create",
      "partitionType": "gpt"
    }
  },
  "filesystems": {
    "main:ESP": {
      "device": "/dev/sdb1",
      "fsType": "vfat",
      "metadata": {
        "diskoSource": "main",
        "diskoType": "filesystem"
      },
      "mountpoint": "/boot",
      "operation": "format",
      "options": [
        "umask=0077"
      ],
      "preserveData": false
    },
    "main:root": {
      "device": "/dev/sdb2",
      "fsType": "xfs",
      "metadata": {
        "diskoSource": "main",
        "diskoType": "filesystem"
      },
      "mountpoint": "/",
      "operation": "format",
      "options": [
        "defaults",
        "pquota"
      ],
      "preserveData": false
    }
  },
  "metadata": {
    "source": "xfs-with-quota.nix",
    "upstream": "nix-community/disko"
  },
  "partitions": {
    "main:ESP": {
      "device": "/dev/sdb",
      "end": "501MiB",
      "metadata": {
        "diskoPartitionType": "EF00",
        "diskoSource": "main"
      },
      "name": "ESP",
      "operation": "create",
      "partitionNumber": "1",
      "partitionType": "primary",
      "size": "500M",
      "start": "1MiB",
      "target": "/dev/sdb1"
    },
    "main:root": {
      "device": "/dev/sdb",
      "end": "100%",
      "metadata": {
        "diskoSource": "main"
      },
      "name": "root",
      "operation": "create",
      "partitionNumber": "2",
      "partitionType": "primary",
      "size": "100%",
      "start": "501MiB",
      "target": "/dev/sdb2"
    }
  },
  "version": 1
}
