{
  "apply": {
    "allowDestructive": true,
    "allowFormat": true,
    "allowGrow": true,
    "allowOffline": true,
    "allowPotentialDataLoss": true,
    "allowShrink": true,
    "requireBackup": false
  },
  "disks": {
    "/dev/sdb": {
      "metadata": {
        "diskoDiskName": "main",
        "diskoSource": "main",
        "originalDevice": "/dev/vdb"
      },
      "operation": "create",
      "partitionType": "gpt"
    }
  },
  "filesystems": {
    "main:ESP": {
      "device": "/dev/sdb1",
      "fsType": "vfat",
      "metadata": {
        "diskoSource": "main",
        "diskoType": "filesystem"
      },
      "mountpoint": "/boot",
      "operation": "format",
      "options": [
        "umask=0077"
      ],
      "preserveData": false
    },
    "pool/home": {
      "device": "/dev/pool/home",
      "fsType": "ext4",
      "metadata": {
        "diskoSource": "lvm:pool/home",
        "diskoType": "filesystem"
      },
      "mountpoint": "/home",
      "operation": "format",
      "preserveData": false
    },
    "pool/root": {
      "device": "/dev/pool/root",
      "fsType": "ext4",
      "metadata": {
        "diskoSource": "lvm:pool/root",
        "diskoType": "filesystem"
      },
      "mountpoint": "/",
      "operation": "format",
      "options": [
        "defaults"
      ],
      "preserveData": false
    }
  },
  "luks": {
    "devices": {
      "crypted": {
        "device": "/dev/sdb2",
        "metadata": {
          "additionalKeyFiles": [
            "/tmp/additionalSecret.key"
          ],
          "diskoSource": "main",
          "settings": {
            "allowDiscards": true,
            "keyFile": "/tmp/secret.key"
          }
        },
        "operation": "format",
        "preserveData": false
      }
    }
  },
  "metadata": {
    "source": "luks-lvm.nix",
    "upstream": "nix-community/disko"
  },
  "partitions": {
    "main:ESP": {
      "device": "/dev/sdb",
      "end": "501MiB",
      "metadata": {
        "diskoPartitionType": "EF00",
        "diskoSource": "main"
      },
      "name": "ESP",
      "operation": "create",
      "partitionNumber": "1",
      "partitionType": "primary",
      "size": "500M",
      "start": "1MiB",
      "target": "/dev/sdb1"
    },
    "main:luks": {
      "device": "/dev/sdb",
      "end": "100%",
      "metadata": {
        "diskoSource": "main"
      },
      "name": "luks",
      "operation": "create",
      "partitionNumber": "2",
      "partitionType": "primary",
      "size": "100%",
      "start": "501MiB",
      "target": "/dev/sdb2"
    }
  },
  "physicalVolumes": {
    "/dev/mapper/crypted": {
      "device": "/dev/mapper/crypted",
      "metadata": {
        "diskoSource": "main:crypted"
      },
      "operation": "create"
    }
  },
  "version": 1,
  "volumeGroups": {
    "pool": {
      "device": "/dev/mapper/crypted",
      "devices": [
        "/dev/mapper/crypted"
      ],
      "metadata": {
        "diskoSource": "main:crypted"
      },
      "operation": "create"
    }
  },
  "volumes": {
    "pool/home": {
      "desiredSize": "10M",
      "metadata": {
        "diskoSource": "lvm_vg:pool"
      },
      "operation": "create",
      "target": "pool/home"
    },
    "pool/raw": {
      "desiredSize": "10M",
      "metadata": {
        "diskoSource": "lvm_vg:pool"
      },
      "operation": "create",
      "target": "pool/raw"
    },
    "pool/root": {
      "desiredSize": "100%",
      "metadata": {
        "diskoSource": "lvm_vg:pool"
      },
      "operation": "create",
      "target": "pool/root"
    }
  }
}
