{
  "apply": {
    "allowDestructive": true,
    "allowFormat": true,
    "allowGrow": true,
    "allowOffline": true,
    "allowPotentialDataLoss": true,
    "allowShrink": true,
    "requireBackup": false
  },
  "disks": {
    "/dev/sdb": {
      "metadata": {
        "diskoDiskName": "main",
        "diskoSource": "main",
        "originalDevice": "/dev/vdb"
      },
      "operation": "create",
      "partitionType": "gpt"
    }
  },
  "filesystems": {
    "main:ESP": {
      "device": "/dev/sdb1",
      "fsType": "vfat",
      "metadata": {
        "diskoSource": "main",
        "diskoType": "filesystem"
      },
      "mountpoint": "/boot",
      "operation": "format",
      "options": [
        "umask=0077"
      ],
      "preserveData": false
    },
    "main:root": {
      "device": "/dev/sdb4",
      "fsType": "ext4",
      "metadata": {
        "diskoSource": "main",
        "diskoType": "filesystem"
      },
      "mountpoint": "/",
      "operation": "format",
      "preserveData": false
    }
  },
  "metadata": {
    "source": "swap.nix",
    "upstream": "nix-community/disko"
  },
  "partitions": {
    "main:encryptedSwap": {
      "device": "/dev/sdb",
      "end": "511MiB",
      "metadata": {
        "diskoSource": "main"
      },
      "name": "encryptedSwap",
      "operation": "create",
      "partitionNumber": "2",
      "partitionType": "primary",
      "size": "10M",
      "start": "501MiB",
      "target": "/dev/sdb2"
    },
    "main:ESP": {
      "device": "/dev/sdb",
      "end": "501MiB",
      "metadata": {
        "diskoPartitionType": "EF00",
        "diskoSource": "main"
      },
      "name": "ESP",
      "operation": "create",
      "partitionNumber": "1",
      "partitionType": "primary",
      "size": "500M",
      "start": "1MiB",
      "target": "/dev/sdb1"
    },
    "main:plainSwap": {
      "device": "/dev/sdb",
      "end": "100%",
      "metadata": {
        "diskoSource": "main"
      },
      "name": "plainSwap",
      "operation": "create",
      "partitionNumber": "3",
      "partitionType": "primary",
      "size": "100%",
      "start": "511MiB",
      "target": "/dev/sdb3"
    },
    "main:root": {
      "device": "/dev/sdb",
      "end": "-1G",
      "metadata": {
        "diskoSource": "main"
      },
      "name": "root",
      "operation": "create",
      "partitionNumber": "4",
      "partitionType": "primary",
      "start": "1535MiB",
      "target": "/dev/sdb4"
    }
  },
  "swaps": {
    "main:encryptedSwap": {
      "device": "/dev/sdb2",
      "metadata": {
        "diskoSource": "main",
        "randomEncryption": true
      },
      "operation": "format",
      "preserveData": false,
      "properties": {
        "priority": "100"
      }
    },
    "main:plainSwap": {
      "device": "/dev/sdb3",
      "metadata": {
        "discardPolicy": "both",
        "diskoSource": "main",
        "resumeDevice": true
      },
      "operation": "format",
      "preserveData": false
    }
  },
  "version": 1
}
