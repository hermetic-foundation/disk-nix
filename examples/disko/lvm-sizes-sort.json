{
  "apply": {
    "allowDestructive": true,
    "allowFormat": true,
    "allowGrow": true,
    "allowOffline": true,
    "allowPotentialDataLoss": true,
    "allowShrink": true,
    "requireBackup": false
  },
  "disks": {
    "/dev/sdb": {
      "metadata": {
        "diskoDiskName": "one",
        "diskoSource": "one",
        "originalDevice": "/dev/disk/by-id/ata-VMware_Virtual_SATA_CDRW_Drive_00000000000000000001"
      },
      "operation": "create",
      "partitionType": "gpt"
    }
  },
  "filesystems": {
    "one:boot": {
      "device": "/dev/sdb1",
      "fsType": "vfat",
      "metadata": {
        "diskoSource": "one",
        "diskoType": "filesystem"
      },
      "mountpoint": "/boot",
      "operation": "format",
      "options": [
        "umask=0077"
      ],
      "preserveData": false
    },
    "pool/home": {
      "device": "/dev/pool/home",
      "fsType": "ext4",
      "metadata": {
        "diskoSource": "lvm:pool/home",
        "diskoType": "filesystem"
      },
      "mountpoint": "/home",
      "operation": "format",
      "preserveData": false
    },
    "pool/root": {
      "device": "/dev/pool/root",
      "fsType": "ext4",
      "metadata": {
        "diskoSource": "lvm:pool/root",
        "diskoType": "filesystem"
      },
      "mountpoint": "/",
      "operation": "format",
      "options": [
        "defaults"
      ],
      "preserveData": false
    }
  },
  "metadata": {
    "source": "lvm-sizes-sort.nix",
    "upstream": "nix-community/disko"
  },
  "partitions": {
    "one:boot": {
      "device": "/dev/sdb",
      "end": "501MiB",
      "metadata": {
        "diskoPartitionType": "EF00",
        "diskoSource": "one"
      },
      "name": "boot",
      "operation": "create",
      "partitionNumber": "1",
      "partitionType": "primary",
      "size": "500M",
      "start": "1MiB",
      "target": "/dev/sdb1"
    },
    "one:primary": {
      "device": "/dev/sdb",
      "end": "100%",
      "metadata": {
        "diskoSource": "one"
      },
      "name": "primary",
      "operation": "create",
      "partitionNumber": "2",
      "partitionType": "primary",
      "size": "100%",
      "start": "501MiB",
      "target": "/dev/sdb2"
    }
  },
  "physicalVolumes": {
    "/dev/sdb2": {
      "device": "/dev/sdb2",
      "metadata": {
        "diskoSource": "one"
      },
      "operation": "create"
    }
  },
  "version": 1,
  "volumeGroups": {
    "pool": {
      "device": "/dev/sdb2",
      "devices": [
        "/dev/sdb2"
      ],
      "metadata": {
        "diskoSource": "one"
      },
      "operation": "create"
    }
  },
  "volumes": {
    "pool/aaa": {
      "desiredSize": "1M",
      "metadata": {
        "diskoSource": "lvm_vg:pool"
      },
      "operation": "create",
      "target": "pool/aaa"
    },
    "pool/home": {
      "desiredSize": "100%FREE",
      "metadata": {
        "diskoSource": "lvm_vg:pool"
      },
      "operation": "create",
      "target": "pool/home"
    },
    "pool/root": {
      "desiredSize": "100M",
      "metadata": {
        "diskoSource": "lvm_vg:pool"
      },
      "operation": "create",
      "target": "pool/root"
    },
    "pool/zzz": {
      "desiredSize": "1M",
      "metadata": {
        "diskoSource": "lvm_vg:pool"
      },
      "operation": "create",
      "target": "pool/zzz"
    }
  }
}
