{
  "apply": {
    "allowDestructive": true,
    "allowFormat": true,
    "allowGrow": true,
    "allowOffline": true,
    "allowPotentialDataLoss": true,
    "allowShrink": true,
    "requireBackup": false
  },
  "btrfsSubvolumes": {
    "main:crypted:/home": {
      "metadata": {
        "diskoSource": "main:crypted",
        "parentFilesystem": "main:crypted"
      },
      "mountpoint": "/home",
      "operation": "create",
      "options": [
        "compress=zstd",
        "noatime"
      ],
      "target": "/home"
    },
    "main:crypted:/nix": {
      "metadata": {
        "diskoSource": "main:crypted",
        "parentFilesystem": "main:crypted"
      },
      "mountpoint": "/nix",
      "operation": "create",
      "options": [
        "compress=zstd",
        "noatime"
      ],
      "target": "/nix"
    },
    "main:crypted:/root": {
      "metadata": {
        "diskoSource": "main:crypted",
        "parentFilesystem": "main:crypted"
      },
      "mountpoint": "/",
      "operation": "create",
      "options": [
        "compress=zstd",
        "noatime"
      ],
      "target": "/root"
    },
    "main:crypted:/swap": {
      "metadata": {
        "diskoSource": "main:crypted",
        "parentFilesystem": "main:crypted",
        "swap": {
          "swapfile": {
            "size": "20M"
          }
        }
      },
      "mountpoint": "/.swapvol",
      "operation": "create",
      "target": "/swap"
    }
  },
  "disks": {
    "/dev/sdb": {
      "metadata": {
        "diskoDiskName": "main",
        "diskoSource": "main",
        "originalDevice": "/dev/vdb"
      },
      "operation": "create",
      "partitionType": "gpt"
    }
  },
  "filesystems": {
    "main:crypted": {
      "device": "/dev/mapper/crypted",
      "fsType": "btrfs",
      "metadata": {
        "diskoSource": "main:crypted",
        "diskoType": "filesystem",
        "extraArgs": [
          "-f"
        ]
      },
      "mountpoint": "main:crypted",
      "operation": "format",
      "preserveData": false
    },
    "main:ESP": {
      "device": "/dev/sdb1",
      "fsType": "vfat",
      "metadata": {
        "diskoSource": "main",
        "diskoType": "filesystem"
      },
      "mountpoint": "/boot",
      "operation": "format",
      "options": [
        "umask=0077"
      ],
      "preserveData": false
    }
  },
  "luks": {
    "devices": {
      "crypted": {
        "device": "/dev/sdb2",
        "metadata": {
          "additionalKeyFiles": [
            "/tmp/additionalSecret.key"
          ],
          "diskoSource": "main",
          "settings": {
            "allowDiscards": true,
            "keyFile": "/tmp/secret.key"
          }
        },
        "operation": "format",
        "preserveData": false
      }
    }
  },
  "metadata": {
    "source": "luks-btrfs-subvolumes.nix",
    "upstream": "nix-community/disko"
  },
  "partitions": {
    "main:ESP": {
      "device": "/dev/sdb",
      "end": "513MiB",
      "metadata": {
        "diskoPartitionType": "EF00",
        "diskoSource": "main"
      },
      "name": "ESP",
      "operation": "create",
      "partitionNumber": "1",
      "partitionType": "primary",
      "size": "512M",
      "start": "1MiB",
      "target": "/dev/sdb1"
    },
    "main:luks": {
      "device": "/dev/sdb",
      "end": "100%",
      "metadata": {
        "diskoSource": "main"
      },
      "name": "luks",
      "operation": "create",
      "partitionNumber": "2",
      "partitionType": "primary",
      "size": "100%",
      "start": "513MiB",
      "target": "/dev/sdb2"
    }
  },
  "version": 1
}
