{
  "apply": {
    "allowDestructive": true,
    "allowFormat": true,
    "allowGrow": true,
    "allowOffline": true,
    "allowPotentialDataLoss": true,
    "allowShrink": true,
    "requireBackup": false
  },
  "disks": {
    "/dev/sdb": {
      "metadata": {
        "diskoDiskName": "vdb",
        "diskoSource": "vdb",
        "originalDevice": "/dev/disk/by-id/some-disk-id"
      },
      "operation": "create",
      "partitionType": "gpt"
    }
  },
  "filesystems": {
    "vdb:ESP": {
      "device": "/dev/sdb1",
      "fsType": "vfat",
      "metadata": {
        "diskoSource": "vdb",
        "diskoType": "filesystem"
      },
      "mountpoint": "/boot",
      "operation": "format",
      "options": [
        "umask=0077"
      ],
      "preserveData": false
    },
    "vdb:name with spaces": {
      "device": "/dev/sdb2",
      "fsType": "vfat",
      "metadata": {
        "diskoSource": "vdb",
        "diskoType": "filesystem"
      },
      "mountpoint": "/name with spaces",
      "operation": "format",
      "preserveData": false
    },
    "vdb:name^with\\some@special#chars": {
      "device": "/dev/sdb3",
      "fsType": "vfat",
      "metadata": {
        "diskoSource": "vdb",
        "diskoType": "filesystem"
      },
      "mountpoint": "/name^with\\some@special#chars",
      "operation": "format",
      "preserveData": false
    },
    "vdb:root": {
      "device": "/dev/sdb4",
      "fsType": "ext4",
      "metadata": {
        "diskoSource": "vdb",
        "diskoType": "filesystem"
      },
      "mountpoint": "/",
      "operation": "format",
      "preserveData": false
    }
  },
  "metadata": {
    "source": "gpt-name-with-whitespace.nix",
    "upstream": "nix-community/disko"
  },
  "partitions": {
    "vdb:ESP": {
      "device": "/dev/sdb",
      "end": "101MiB",
      "metadata": {
        "diskoPartitionType": "EF00",
        "diskoSource": "vdb"
      },
      "name": "ESP",
      "operation": "create",
      "partitionNumber": "1",
      "partitionType": "primary",
      "size": "100M",
      "start": "1MiB",
      "target": "/dev/sdb1"
    },
    "vdb:name with spaces": {
      "device": "/dev/sdb",
      "end": "201MiB",
      "metadata": {
        "diskoSource": "vdb"
      },
      "name": "name with spaces",
      "operation": "create",
      "partitionNumber": "2",
      "partitionType": "primary",
      "size": "100M",
      "start": "101MiB",
      "target": "/dev/sdb2"
    },
    "vdb:name^with\\some@special#chars": {
      "device": "/dev/sdb",
      "end": "301MiB",
      "metadata": {
        "diskoSource": "vdb"
      },
      "name": "name^with\\some@special#chars",
      "operation": "create",
      "partitionNumber": "3",
      "partitionType": "primary",
      "size": "100M",
      "start": "201MiB",
      "target": "/dev/sdb3"
    },
    "vdb:root": {
      "device": "/dev/sdb",
      "end": "100%",
      "metadata": {
        "diskoSource": "vdb"
      },
      "name": "root",
      "operation": "create",
      "partitionNumber": "4",
      "partitionType": "primary",
      "size": "100%",
      "start": "301MiB",
      "target": "/dev/sdb4"
    }
  },
  "version": 1
}
