{
  "apply": {
    "allowDestructive": true,
    "allowFormat": true,
    "allowGrow": true,
    "allowOffline": true,
    "allowPotentialDataLoss": true,
    "allowShrink": true,
    "requireBackup": false
  },
  "disks": {
    "/dev/sdb": {
      "metadata": {
        "diskoDiskName": "main",
        "diskoSource": "main",
        "originalDevice": "/dev/disk/by-diskseq/1"
      },
      "operation": "create",
      "partitionType": "gpt"
    }
  },
  "filesystems": {
    "main:ESP": {
      "device": "/dev/sdb1",
      "fsType": "vfat",
      "metadata": {
        "diskoSource": "main",
        "diskoType": "filesystem"
      },
      "mountpoint": "/boot",
      "operation": "format",
      "options": [
        "umask=0077"
      ],
      "preserveData": false
    },
    "main:root": {
      "device": "/dev/sdb2",
      "fsType": "btrfs",
      "metadata": {
        "diskoSource": "main",
        "diskoType": "filesystem",
        "extraArgs": [
          "-f"
        ]
      },
      "mountpoint": "/",
      "operation": "format",
      "options": [
        "compress=zstd",
        "noatime"
      ],
      "preserveData": false
    }
  },
  "metadata": {
    "source": "btrfs-only-root-subvolume.nix",
    "upstream": "nix-community/disko"
  },
  "partitions": {
    "main:ESP": {
      "device": "/dev/sdb",
      "end": "128M",
      "metadata": {
        "diskoPartitionType": "EF00",
        "diskoSource": "main",
        "priority": 1
      },
      "name": "ESP",
      "operation": "create",
      "partitionNumber": "1",
      "partitionType": "primary",
      "start": "1M",
      "target": "/dev/sdb1"
    },
    "main:root": {
      "device": "/dev/sdb",
      "end": "100%",
      "metadata": {
        "diskoSource": "main"
      },
      "name": "root",
      "operation": "create",
      "partitionNumber": "2",
      "partitionType": "primary",
      "size": "100%",
      "start": "128MiB",
      "target": "/dev/sdb2"
    }
  },
  "version": 1
}
