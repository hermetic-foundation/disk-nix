{
  "apply": {
    "allowDestructive": true,
    "allowFormat": true,
    "allowGrow": true,
    "allowOffline": true,
    "allowPotentialDataLoss": true,
    "allowShrink": true,
    "requireBackup": false
  },
  "disks": {
    "/dev/sdb": {
      "metadata": {
        "diskoDiskName": "disk1",
        "diskoSource": "disk1",
        "originalDevice": "/dev/my-disk"
      },
      "operation": "create",
      "partitionType": "gpt"
    },
    "/dev/sdc": {
      "metadata": {
        "diskoDiskName": "disk2",
        "diskoSource": "disk2",
        "originalDevice": "/dev/my-disk2"
      },
      "operation": "create",
      "partitionType": "gpt"
    }
  },
  "filesystems": {
    "mdadm:raid5:primary": {
      "device": "/dev/md/raid5p1",
      "fsType": "ext4",
      "metadata": {
        "diskoSource": "mdadm:raid5",
        "diskoType": "filesystem"
      },
      "mountpoint": "/",
      "operation": "format",
      "preserveData": false
    }
  },
  "mdRaids": {
    "raid5": {
      "devices": [
        "/dev/sdb2",
        "/dev/sdc2"
      ],
      "level": "5",
      "metadata": {
        "diskoSource": "raid5",
        "extraArgs": [
          "--assume-clean"
        ]
      },
      "operation": "create",
      "target": "/dev/md/raid5"
    }
  },
  "metadata": {
    "source": "mdadm-raid5-args.nix",
    "upstream": "nix-community/disko"
  },
  "partitions": {
    "disk1:boot": {
      "device": "/dev/sdb",
      "end": "2MiB",
      "metadata": {
        "diskoPartitionType": "EF02",
        "diskoSource": "disk1"
      },
      "name": "boot",
      "operation": "create",
      "partitionNumber": "1",
      "partitionType": "primary",
      "size": "1M",
      "start": "1MiB",
      "target": "/dev/sdb1"
    },
    "disk1:mdadm": {
      "device": "/dev/sdb",
      "end": "100%",
      "metadata": {
        "diskoSource": "disk1"
      },
      "name": "mdadm",
      "operation": "create",
      "partitionNumber": "2",
      "partitionType": "primary",
      "size": "100%",
      "start": "2MiB",
      "target": "/dev/sdb2"
    },
    "disk2:boot": {
      "device": "/dev/sdc",
      "end": "2MiB",
      "metadata": {
        "diskoPartitionType": "EF02",
        "diskoSource": "disk2"
      },
      "name": "boot",
      "operation": "create",
      "partitionNumber": "1",
      "partitionType": "primary",
      "size": "1M",
      "start": "1MiB",
      "target": "/dev/sdc1"
    },
    "disk2:mdadm": {
      "device": "/dev/sdc",
      "end": "100%",
      "metadata": {
        "diskoSource": "disk2"
      },
      "name": "mdadm",
      "operation": "create",
      "partitionNumber": "2",
      "partitionType": "primary",
      "size": "100%",
      "start": "2MiB",
      "target": "/dev/sdc2"
    },
    "mdadm:raid5:primary": {
      "device": "/dev/md/raid5",
      "end": "100%",
      "metadata": {
        "diskoSource": "mdadm:raid5"
      },
      "name": "primary",
      "operation": "create",
      "partitionNumber": "1",
      "partitionType": "primary",
      "size": "100%",
      "start": "1MiB",
      "target": "/dev/md/raid5p1"
    }
  },
  "version": 1
}
