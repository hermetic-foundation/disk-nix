{
  "apply": {
    "allowDestructive": true,
    "allowFormat": true,
    "allowGrow": true,
    "allowOffline": true,
    "allowPotentialDataLoss": true,
    "allowShrink": true,
    "requireBackup": false
  },
  "disks": {
    "/dev/sdb": {
      "metadata": {
        "diskoDiskNames": [
          "one"
        ],
        "diskoSource": "one",
        "originalDevices": [
          "/dev/sda"
        ]
      },
      "operation": "create",
      "partitionType": "gpt"
    },
    "/dev/sdc": {
      "metadata": {
        "diskoDiskNames": [
          "two"
        ],
        "diskoSource": "two",
        "originalDevices": [
          "/dev/sdb"
        ]
      },
      "operation": "create",
      "partitionType": "gpt"
    }
  },
  "filesystems": {
    "boot": {
      "device": "/dev/md/boot",
      "fsType": "vfat",
      "metadata": {
        "diskoSource": "mdadm:boot",
        "diskoType": "filesystem"
      },
      "mountpoint": "/boot",
      "operation": "format",
      "options": [
        "umask=0077"
      ],
      "preserveData": false
    },
    "pool/home": {
      "device": "/dev/pool/home",
      "fsType": "ext4",
      "metadata": {
        "diskoSource": "lvm:pool/home",
        "diskoType": "filesystem"
      },
      "mountpoint": "/home",
      "operation": "format",
      "preserveData": false
    },
    "pool/root": {
      "device": "/dev/pool/root",
      "fsType": "ext4",
      "metadata": {
        "diskoSource": "lvm:pool/root",
        "diskoType": "filesystem"
      },
      "mountpoint": "/",
      "operation": "format",
      "options": [
        "defaults"
      ],
      "preserveData": false
    }
  },
  "mdRaids": {
    "boot": {
      "devices": [
        "/dev/sdb1",
        "/dev/sdc1"
      ],
      "level": "1",
      "metadata": {
        "diskoSource": "boot",
        "metadata": "1.0"
      },
      "operation": "create",
      "target": "/dev/md/boot"
    }
  },
  "metadata": {
    "source": "lvm-raid.nix",
    "upstream": "nix-community/disko"
  },
  "partitions": {
    "one:boot": {
      "device": "/dev/sdb",
      "end": "501MiB",
      "metadata": {
        "diskoPartitionType": "EF00",
        "diskoSource": "one"
      },
      "name": "boot",
      "operation": "create",
      "partitionNumber": "1",
      "partitionType": "primary",
      "size": "500M",
      "start": "1MiB",
      "target": "/dev/sdb1"
    },
    "one:primary": {
      "device": "/dev/sdb",
      "end": "100%",
      "metadata": {
        "diskoSource": "one"
      },
      "name": "primary",
      "operation": "create",
      "partitionNumber": "2",
      "partitionType": "primary",
      "size": "100%",
      "start": "501MiB",
      "target": "/dev/sdb2"
    },
    "two:boot": {
      "device": "/dev/sdc",
      "end": "501MiB",
      "metadata": {
        "diskoPartitionType": "EF00",
        "diskoSource": "two"
      },
      "name": "boot",
      "operation": "create",
      "partitionNumber": "1",
      "partitionType": "primary",
      "size": "500M",
      "start": "1MiB",
      "target": "/dev/sdc1"
    },
    "two:primary": {
      "device": "/dev/sdc",
      "end": "100%",
      "metadata": {
        "diskoSource": "two"
      },
      "name": "primary",
      "operation": "create",
      "partitionNumber": "2",
      "partitionType": "primary",
      "size": "100%",
      "start": "501MiB",
      "target": "/dev/sdc2"
    }
  },
  "physicalVolumes": {
    "/dev/sdb2": {
      "device": "/dev/sdb2",
      "metadata": {
        "diskoSource": "one"
      },
      "operation": "create"
    },
    "/dev/sdc2": {
      "device": "/dev/sdc2",
      "metadata": {
        "diskoSource": "two"
      },
      "operation": "create"
    }
  },
  "version": 1,
  "volumeGroups": {
    "pool": {
      "device": "/dev/sdb2",
      "devices": [
        "/dev/sdb2",
        "/dev/sdc2"
      ],
      "metadata": {
        "diskoSource": "one"
      },
      "operation": "create"
    }
  },
  "volumes": {
    "pool/home": {
      "desiredSize": "10M",
      "metadata": {
        "diskoSource": "lvm_vg:pool",
        "lvmType": "raid0"
      },
      "operation": "create",
      "target": "pool/home"
    },
    "pool/root": {
      "desiredSize": "100M",
      "metadata": {
        "diskoSource": "lvm_vg:pool",
        "lvmType": "mirror"
      },
      "operation": "create",
      "target": "pool/root"
    }
  }
}
