{
  "version": 1,
  "filesystems": {
    "home-check": {
      "mountpoint": "/home",
      "device": "/dev/disk/by-label/home",
      "fsType": "ext4",
      "operation": "check"
    },
    "data-scrub": {
      "mountpoint": "/data",
      "fsType": "btrfs",
      "operation": "scrub"
    },
    "scratch-trim": {
      "mountpoint": "/scratch",
      "fsType": "xfs",
      "operation": "trim"
    },
    "scratch-remount": {
      "mountpoint": "/scratch",
      "fsType": "xfs",
      "operation": "remount",
      "options": [
        "rw",
        "noatime",
        "discard=async"
      ]
    }
  },
  "pools": {
    "tank": {
      "operation": "rebalance",
      "addDevices": [
        "/dev/disk/by-id/nvme-replacement"
      ],
      "removeDevices": [
        "/dev/disk/by-id/old-disk"
      ],
      "properties": {
        "autotrim": "on"
      }
    },
    "vault": {
      "operation": "import",
      "readOnly": true
    },
    "moveme": {
      "operation": "export"
    }
  },
  "datasets": {
    "tank/home": {
      "operation": "create"
    },
    "tank/legacy": {
      "operation": "rename",
      "renameTo": "tank/legacy-staged"
    },
    "tank/home-review": {
      "operation": "promote"
    },
    "tank/archive": {
      "destroy": true
    }
  },
  "zvols": {
    "tank/vm/root": {
      "operation": "grow",
      "desiredSize": "80GiB"
    }
  },
  "volumes": {
    "vg0/home": {
      "operation": "grow",
      "preserveData": true
    },
    "vg0/scratch": {
      "operation": "create",
      "desiredSize": "10GiB"
    },
    "vg0/archive": {
      "operation": "deactivate"
    }
  },
  "thinPools": {
    "vg0/thinpool": {
      "operation": "grow",
      "desiredSize": "500GiB"
    },
    "vg0/newthin": {
      "operation": "create",
      "desiredSize": "100GiB"
    }
  },
  "volumeGroups": {
    "importvg": {
      "operation": "import"
    },
    "exportvg": {
      "operation": "export"
    },
    "activevg": {
      "operation": "activate"
    },
    "refreshvg": {
      "operation": "rescan"
    }
  },
  "lvmSnapshots": {
    "vg0/root-snap": {
      "operation": "snapshot",
      "target": "vg0/root",
      "desiredSize": "20GiB"
    }
  },
  "lvmCaches": {
    "vg0/root": {
      "operation": "create",
      "device": "vg0/root-cache",
      "properties": {
        "lvm.cache-mode": "writethrough"
      }
    }
  },
  "loopDevices": {
    "/dev/loop7": {
      "operation": "create",
      "device": "/var/lib/images/root.img"
    }
  },
  "mdRaids": {
    "existing": {
      "target": "/dev/md/existing",
      "operation": "assemble",
      "devices": [
        "/dev/disk/by-id/existing-md-a",
        "/dev/disk/by-id/existing-md-b"
      ]
    },
    "oldroot": {
      "target": "/dev/md/oldroot",
      "operation": "stop"
    },
    "inventory": {
      "operation": "rescan"
    },
    "root": {
      "target": "/dev/md/root",
      "addDevices": [
        "/dev/disk/by-id/nvme-md-spare"
      ]
    }
  },
  "multipathMaps": {
    "mpatha": {
      "target": "mpatha",
      "addDevices": [
        "/dev/sdb"
      ]
    },
    "mpathb": {
      "target": "mpathb",
      "operation": "rescan"
    }
  },
  "vdoVolumes": {
    "archive": {
      "operation": "grow",
      "desiredSize": "4TiB",
      "properties": {
        "writePolicy": "sync",
        "compression": "enabled",
        "deduplication": "disabled"
      }
    },
    "warmArchive": {
      "operation": "start"
    },
    "coldArchive": {
      "operation": "stop"
    },
    "refreshArchive": {
      "operation": "rescan"
    }
  },
  "physicalVolumes": {
    "/dev/disk/by-id/nvme-pv-grow": {
      "operation": "grow"
    },
    "/dev/disk/by-id/nvme-pv-refresh": {
      "operation": "rescan"
    }
  },
  "luksKeyslots": {
    "cryptroot:1": {
      "operation": "add-key",
      "device": "/dev/disk/by-id/root-luks",
      "metadata": {
        "keySlot": "1",
        "newKeyFile": "/run/keys/root-new"
      }
    },
    "cryptroot:2": {
      "operation": "remove-key",
      "device": "/dev/disk/by-id/root-luks",
      "metadata": {
        "keySlot": "2"
      }
    }
  },
  "luksTokens": {
    "cryptroot:0": {
      "operation": "import-token",
      "device": "/dev/disk/by-id/root-luks",
      "metadata": {
        "tokenId": "0",
        "tokenFile": "/run/keys/root-token.json"
      }
    },
    "cryptroot:1": {
      "operation": "remove-token",
      "device": "/dev/disk/by-id/root-luks",
      "metadata": {
        "tokenId": "1"
      }
    }
  },
  "btrfsSubvolumes": {
    "/mnt/persist/@home": {
      "operation": "create",
      "path": "/mnt/persist/@home"
    }
  },
  "btrfsQgroups": {
    "0/257": {
      "target": "/mnt/persist",
      "properties": {
        "limit": "25GiB",
        "maxExclusive": "10GiB"
      }
    }
  },
  "partitions": {
    "root": {
      "operation": "grow",
      "device": "/dev/disk/by-id/nvme-root-part2",
      "desiredSize": "100%"
    },
    "data-table": {
      "operation": "rescan",
      "device": "/dev/disk/by-id/nvme-data"
    }
  },
  "swaps": {
    "primary": {
      "device": "/dev/disk/by-label/swap",
      "preserveData": false
    }
  },
  "luks": {
    "devices": {
      "cryptroot": {
        "name": "cryptroot",
        "device": "/dev/disk/by-partuuid/root",
        "operation": "grow"
      },
      "cryptarchive": {
        "name": "cryptarchive",
        "device": "/dev/disk/by-id/archive-luks",
        "operation": "open"
      },
      "cryptclosed": {
        "name": "cryptclosed",
        "device": "/dev/disk/by-id/closed-luks",
        "operation": "close"
      }
    }
  },
  "luns": {
    "iqn.2026-06.example:storage/root:0": {
      "operation": "grow",
      "desiredSize": "2TiB",
      "device": "/dev/disk/by-path/ip-192.0.2.10:3260-iscsi-iqn.2026-06.example:storage-lun-0",
      "devices": [
        "/dev/disk/by-path/ip-192.0.2.11:3260-iscsi-iqn.2026-06.example:storage-lun-0"
      ]
    },
    "iqn.2026-06.example:storage/new:2": {
      "operation": "attach",
      "device": "/dev/disk/by-path/ip-192.0.2.10:3260-iscsi-iqn.2026-06.example:storage-lun-2"
    },
    "iqn.2026-06.example:storage/old:3": {
      "operation": "detach",
      "devices": [
        "/dev/disk/by-path/ip-192.0.2.11:3260-iscsi-iqn.2026-06.example:storage-lun-3"
      ]
    },
    "iqn.2026-06.example:storage/rescan:4": {
      "operation": "rescan",
      "devices": [
        "/dev/disk/by-path/ip-192.0.2.10:3260-iscsi-iqn.2026-06.example:storage-lun-4"
      ]
    }
  },
  "iscsiSessions": {
    "iqn.2026-06.example:storage.login": {
      "operation": "login",
      "portal": "192.0.2.10:3260"
    },
    "iqn.2026-06.example:storage.logout": {
      "operation": "logout",
      "portal": "192.0.2.11:3260"
    },
    "iqn.2026-06.example:storage.rescan": {
      "operation": "rescan",
      "portal": "192.0.2.10:3260"
    }
  },
  "nvmeNamespaces": {
    "/dev/nvme0": {
      "operation": "create",
      "desiredSize": "100G",
      "namespaceId": "4",
      "controllers": "0x1"
    },
    "/dev/nvme1": {
      "operation": "rescan"
    }
  },
  "exports": {
    "/srv/share": {
      "operation": "export",
      "client": "192.0.2.0/24",
      "options": "rw,sync,no_subtree_check"
    },
    "/srv/old-share": {
      "operation": "unexport",
      "client": "192.0.2.55"
    }
  },
  "nfs": {
    "mounts": {
      "/srv/shared": {
        "operation": "mount",
        "source": "nas.example.com:/srv/shared",
        "fsType": "nfs4",
        "options": [
          "_netdev",
          "vers=4.2"
        ]
      },
      "/srv/tuned": {
        "operation": "remount",
        "source": "nas.example.com:/srv/tuned",
        "fsType": "nfs4",
        "options": [
          "_netdev",
          "ro",
          "vers=4.2"
        ]
      },
      "/srv/old": {
        "operation": "unmount",
        "source": "nas.example.com:/srv/old"
      }
    }
  },
  "snapshots": {
    "tank/home@before-upgrade": {
      "target": "tank/home"
    },
    "tank/home@before-prune": {
      "target": "tank/home",
      "renameTo": "tank/home@retained"
    },
    "tank/root@rollback-point": {
      "target": "tank/root",
      "rollback": true
    }
  },
  "caches": {
    "tank/l2arc0": {
      "operation": "replace-device",
      "replaceDevices": {
        "/dev/disk/by-id/old-cache": "/dev/disk/by-id/new-cache"
      }
    },
    "/dev/bcache0": {
      "operation": "rescan",
      "addDevices": [
        "cache-set-uuid"
      ],
      "properties": {
        "bcache.cache-mode": "writethrough"
      }
    }
  }
}
