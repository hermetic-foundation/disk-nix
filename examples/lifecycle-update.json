{
  "version": 1,
  "pools": {
    "tank": {
      "operation": "rebalance",
      "addDevices": [
        "/dev/disk/by-id/nvme-replacement"
      ],
      "removeDevices": [
        "/dev/disk/by-id/old-disk"
      ],
      "properties": {
        "autotrim": "on"
      }
    }
  },
  "datasets": {
    "tank/home": {
      "operation": "create"
    },
    "tank/archive": {
      "destroy": true
    }
  },
  "zvols": {
    "tank/vm/root": {
      "operation": "grow",
      "desiredSize": "80GiB"
    }
  },
  "volumes": {
    "vg0/home": {
      "operation": "grow",
      "preserveData": true
    },
    "vg0/scratch": {
      "operation": "create",
      "desiredSize": "10GiB"
    }
  },
  "thinPools": {
    "vg0/thinpool": {
      "operation": "grow",
      "desiredSize": "500GiB"
    },
    "vg0/newthin": {
      "operation": "create",
      "desiredSize": "100GiB"
    }
  },
  "lvmSnapshots": {
    "vg0/root-snap": {
      "operation": "snapshot",
      "target": "vg0/root",
      "desiredSize": "20GiB"
    }
  },
  "loopDevices": {
    "/dev/loop7": {
      "operation": "create",
      "device": "/var/lib/images/root.img"
    }
  },
  "mdRaids": {
    "root": {
      "target": "/dev/md/root",
      "addDevices": [
        "/dev/disk/by-id/nvme-md-spare"
      ]
    }
  },
  "multipathMaps": {
    "mpatha": {
      "target": "mpatha",
      "addDevices": [
        "/dev/sdb"
      ]
    }
  },
  "vdoVolumes": {
    "archive": {
      "operation": "grow",
      "desiredSize": "4TiB"
    }
  },
  "btrfsSubvolumes": {
    "/mnt/persist/@home": {
      "operation": "create",
      "path": "/mnt/persist/@home"
    }
  },
  "partitions": {
    "root": {
      "operation": "grow",
      "device": "/dev/disk/by-id/nvme-root-part2",
      "desiredSize": "100%"
    }
  },
  "swaps": {
    "primary": {
      "device": "/dev/disk/by-label/swap",
      "preserveData": false
    }
  },
  "luks": {
    "devices": {
      "cryptroot": {
        "name": "cryptroot",
        "device": "/dev/disk/by-partuuid/root",
        "operation": "grow"
      }
    }
  },
  "luns": {
    "iqn.2026-06.example:storage/root:0": {
      "operation": "grow"
    }
  },
  "exports": {
    "/srv/share": {
      "operation": "create",
      "client": "192.0.2.0/24",
      "options": "rw,sync,no_subtree_check"
    }
  },
  "snapshots": {
    "tank/home@before-upgrade": {
      "target": "tank/home"
    },
    "tank/root@rollback-point": {
      "target": "tank/root",
      "rollback": true
    }
  },
  "caches": {
    "tank/l2arc0": {
      "operation": "replace-device",
      "replaceDevices": {
        "/dev/disk/by-id/old-cache": "/dev/disk/by-id/new-cache"
      }
    },
    "/dev/bcache0": {
      "addDevices": [
        "cache-set-uuid"
      ],
      "properties": {
        "bcache.cache-mode": "writethrough"
      }
    }
  }
}
