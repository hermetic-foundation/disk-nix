{
  "version": 1,
  "filesystems": {
    "home-check": {
      "mountpoint": "/home",
      "device": "/dev/disk/by-label/home",
      "fsType": "ext4",
      "operation": "check"
    },
    "data-scrub": {
      "mountpoint": "/data",
      "fsType": "btrfs",
      "operation": "scrub"
    },
    "scratch-trim": {
      "mountpoint": "/scratch",
      "fsType": "xfs",
      "operation": "trim"
    }
  },
  "pools": {
    "tank": {
      "operation": "rebalance",
      "addDevices": [
        "/dev/disk/by-id/nvme-replacement"
      ],
      "removeDevices": [
        "/dev/disk/by-id/old-disk"
      ],
      "properties": {
        "autotrim": "on"
      }
    },
    "vault": {
      "operation": "import",
      "readOnly": true
    },
    "moveme": {
      "operation": "export"
    }
  },
  "datasets": {
    "tank/home": {
      "operation": "create"
    },
    "tank/legacy": {
      "operation": "rename",
      "renameTo": "tank/legacy-staged"
    },
    "tank/home-review": {
      "operation": "promote"
    },
    "tank/archive": {
      "destroy": true
    }
  },
  "zvols": {
    "tank/vm/root": {
      "operation": "grow",
      "desiredSize": "80GiB"
    }
  },
  "volumes": {
    "vg0/home": {
      "operation": "grow",
      "preserveData": true
    },
    "vg0/scratch": {
      "operation": "create",
      "desiredSize": "10GiB"
    },
    "vg0/archive": {
      "operation": "deactivate"
    }
  },
  "thinPools": {
    "vg0/thinpool": {
      "operation": "grow",
      "desiredSize": "500GiB"
    },
    "vg0/newthin": {
      "operation": "create",
      "desiredSize": "100GiB"
    }
  },
  "volumeGroups": {
    "importvg": {
      "operation": "import"
    },
    "exportvg": {
      "operation": "export"
    },
    "activevg": {
      "operation": "activate"
    }
  },
  "lvmSnapshots": {
    "vg0/root-snap": {
      "operation": "snapshot",
      "target": "vg0/root",
      "desiredSize": "20GiB"
    }
  },
  "lvmCaches": {
    "vg0/root": {
      "operation": "create",
      "device": "vg0/root-cache",
      "properties": {
        "lvm.cache-mode": "writethrough"
      }
    }
  },
  "loopDevices": {
    "/dev/loop7": {
      "operation": "create",
      "device": "/var/lib/images/root.img"
    }
  },
  "mdRaids": {
    "root": {
      "target": "/dev/md/root",
      "addDevices": [
        "/dev/disk/by-id/nvme-md-spare"
      ]
    }
  },
  "multipathMaps": {
    "mpatha": {
      "target": "mpatha",
      "addDevices": [
        "/dev/sdb"
      ]
    }
  },
  "vdoVolumes": {
    "archive": {
      "operation": "grow",
      "desiredSize": "4TiB",
      "properties": {
        "writePolicy": "sync",
        "compression": "enabled",
        "deduplication": "disabled"
      }
    }
  },
  "physicalVolumes": {
    "/dev/disk/by-id/nvme-pv-grow": {
      "operation": "grow"
    }
  },
  "luksKeyslots": {
    "cryptroot:1": {
      "operation": "create",
      "device": "/dev/disk/by-id/root-luks",
      "metadata": {
        "keySlot": "1",
        "newKeyFile": "/run/keys/root-new"
      }
    }
  },
  "luksTokens": {
    "cryptroot:0": {
      "operation": "create",
      "device": "/dev/disk/by-id/root-luks",
      "metadata": {
        "tokenId": "0",
        "tokenFile": "/run/keys/root-token.json"
      }
    }
  },
  "btrfsSubvolumes": {
    "/mnt/persist/@home": {
      "operation": "create",
      "path": "/mnt/persist/@home"
    }
  },
  "btrfsQgroups": {
    "0/257": {
      "target": "/mnt/persist",
      "properties": {
        "limit": "25GiB",
        "maxExclusive": "10GiB"
      }
    }
  },
  "partitions": {
    "root": {
      "operation": "grow",
      "device": "/dev/disk/by-id/nvme-root-part2",
      "desiredSize": "100%"
    }
  },
  "swaps": {
    "primary": {
      "device": "/dev/disk/by-label/swap",
      "preserveData": false
    }
  },
  "luks": {
    "devices": {
      "cryptroot": {
        "name": "cryptroot",
        "device": "/dev/disk/by-partuuid/root",
        "operation": "grow"
      }
    }
  },
  "luns": {
    "iqn.2026-06.example:storage/root:0": {
      "operation": "grow",
      "desiredSize": "2TiB",
      "device": "/dev/disk/by-path/ip-192.0.2.10:3260-iscsi-iqn.2026-06.example:storage-lun-0",
      "devices": [
        "/dev/disk/by-path/ip-192.0.2.11:3260-iscsi-iqn.2026-06.example:storage-lun-0"
      ]
    }
  },
  "nvmeNamespaces": {
    "/dev/nvme0": {
      "operation": "create",
      "desiredSize": "100G",
      "namespaceId": "4",
      "controllers": "0x1"
    }
  },
  "exports": {
    "/srv/share": {
      "operation": "create",
      "client": "192.0.2.0/24",
      "options": "rw,sync,no_subtree_check"
    }
  },
  "snapshots": {
    "tank/home@before-upgrade": {
      "target": "tank/home"
    },
    "tank/home@before-prune": {
      "target": "tank/home",
      "renameTo": "tank/home@retained"
    },
    "tank/root@rollback-point": {
      "target": "tank/root",
      "rollback": true
    }
  },
  "caches": {
    "tank/l2arc0": {
      "operation": "replace-device",
      "replaceDevices": {
        "/dev/disk/by-id/old-cache": "/dev/disk/by-id/new-cache"
      }
    },
    "/dev/bcache0": {
      "addDevices": [
        "cache-set-uuid"
      ],
      "properties": {
        "bcache.cache-mode": "writethrough"
      }
    }
  }
}
